{
  "name": "innate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @innate/web dev",
    "run:project": "bash run.sh",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "clean": "rm -rf .next node_modules && pnpm -r clean",
    "sync": "pnpm --filter @innate/task-watcher task-watcher sync",
    "sync:data": "pnpm --filter @innate/web sync:data",
    "sync:issues": "pnpm --filter @innate/web sync:issues",
    "sync:projects": "pnpm --filter @innate/web sync:projects",
    "sync:agents": "pnpm --filter @innate/web sync:agents",
    "sync:weekly": "pnpm --filter @innate/web sync:weekly",
    "sync:insights": "pnpm --filter @innate/web sync:insights",
    "sync:collections": "pnpm --filter @innate/web sync:collections"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "playwright": "^1.60.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.2"
}
