# Source: https://betterstack.com/community/guides/scaling-nodejs/husky-and-lint-staged/
# Original language: json
# Normalized: json
# Block index: 16

[label .lintstagedrc.json]
{
  "*.{js,jsx,ts,tsx}": [
    "eslint --fix --max-warnings=0",
    "prettier --write"
  ],
  "*.{json,css,md}": [
    "prettier --write"
  ]
}