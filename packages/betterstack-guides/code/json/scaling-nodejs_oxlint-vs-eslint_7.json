[label .oxlintrc.json]
{
  "rules": {
    "typescript/no-explicit-any": "error",
    "react/jsx-key": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "typescript/no-explicit-any": "off"
      }
    }
  ]
}